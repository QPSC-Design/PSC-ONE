	i2s_test1:RV32ISP_chip_test:./mem/i2s_test1.mem:0x0abc0123 \

# ============================================================
# テストプログラムの切り替え（basic / long / single)
# ============================================================
# デフォルトはbasic
TEST_PROGRAM_LIST ?= basic

ifeq ($(TEST_PROGRAM_LIST),basic)
PSCONE_TESTS = $(PSCONE_BASIC_TESTS)
else ifeq ($(TEST_PROGRAM_LIST),long)
PSCONE_TESTS = $(PSCONE_LONG_TESTS)
else ifeq ($(TEST_PROGRAM_LIST),single)
PSCONE_TESTS = $(PSCONE_SINGLE_TEST)
else
$(error TEST_PROGRAM_LIST=$(TEST_PROGRAM_LIST) は不正です。basic または long, single を指定してください)
endif

# run test
.PHONY: simulate_PSC_ONE_TESTS
simulate_PSC_ONE_TESTS:
	@mkdir -p ./wave
	@echo "MODE=$(MODE)"
	@echo "CPU_VERSION=$(CPU_VERSION)"
	@echo "TEST_PROGRAM_LIST=$(TEST_PROGRAM_LIST)"
	@set -e; \
	mkdir -p log; \
	run_log=log/test_result_$$(date +%Y%m%d_%H%M%S).log; \
	echo "[INFO] LOG FILE = $$run_log"; \
	for t in $(PSCONE_TESTS); do \
		name=$$(echo $$t | cut -d: -f1); \
		cocotb_file=$$(echo $$t | cut -d: -f2); \
		mem_file=$$(echo $$t | cut -d: -f3); \
		expected=$$(echo $$t | cut -d: -f4); \
		echo ""; \
		echo "========================================"; \
		echo "[TEST] $$name"; \
		echo "[MEM ] $$mem_file"; \
		echo "[EXP ] $$expected"; \
		echo "[LOG ] $$run_log"; \
		echo "========================================"; \
		$(MAKE) clean; \
		$(MAKE) -C ./cpp clean; \
		$(MAKE) -C ./cpp $$name; \
		tmp=$$(mktemp); \
		head -n 2048 "$$mem_file" > $$tmp; \
		cp $$tmp ./mem/test_program.mem; \
		rm -f $$tmp; \
		COCOTB_TEST_MODULES=cocotb_tb.cpu.$$cocotb_file \
		TEST_NAME=$$name \
		PSC_LOGFILE=$$run_log \
		PROGRAM_FILE=$$mem_file \
		EXPECTED_RESULT=$$expected \
		TOPLEVEL=$(PSCONE_TOP) \
		TOPLEVEL_LANG=verilog \
		SIM=$(SIM) \
		VERILOG_SOURCES="$(INPUT_FILE_PSCONE)" \
		COMPILE_ARGS="$(TOP_COMPILE_ARGS) $(VCD_COMPILE_ARGS)" \
		EXTRA_ARGS="$(EXTRA_ARGS) $(VDEF)" \
		make --silent -f $(COCOTB_MAKEFILE); \
	done; \
	echo ""; \
	echo "========================================"; \
	echo "✅ All PSC-ONE tests completed"; \
	echo "📄 Log : $$run_log"; \
	echo "========================================"